{
  "AppSettings": {
    "ApiVersions": [ "v1" ],
    "ApiDocumentationTool": "SwaggerUI", // Options: "None", "SwaggerUI", "Scalar"
    "SupportedCultures": [ "en", "it" ]
  },
  "SwaggerSettings": {
    "IsEnabled": true,
    "RequireAuthentication": false,
    "UserName": "admin",
    "Password": "password"
  },
  "ConnectionStrings": {
    "SqlConnection": "Data Source=[HOSTNAME];Initial Catalog=OperazioniAvvio;User ID=[USERNAME];Password=[PASSWORD];Encrypt=False",
    "LogsConnection": "Data Source=[HOSTNAME];Initial Catalog=OperazioniAvvio_Logs;User ID=[USERNAME];Password=[PASSWORD];Encrypt=False"
  },
  "JwtSettings": {
    "DefaultScheme": "Bearer", // Optional
    "JwtBearer": {
      "SchemeName": "Bearer", // Default: Bearer
      //"NameClaimType": "user_name", // Default: http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name
      //"RoleClaimType": "user_role", // Default: http://schemas.microsoft.com/ws/2008/06/identity/claims/role
      "SecurityKey": "SecurityKey-512-char", // Required
      "Algorithm": "HS256", // Default: HS256
      "Issuers": [ "issuer" ], // Optional
      "Audiences": [ "audience" ], // Optional
      "ExpirationTime": "01:00:00", // Default: No expiration
      "ClockSkew": "00:02:00" // Default: 5 minutes
    }
  },
  "CacheSettings": {
    "CacheType": "Memory" // Required, values: "Memory", "Redis"
  },
  "RedisSettings": {
    "InstanceName": "MinimalApi.Api", // Optional, used as prefix for all Redis keys
    "EndPoints": "localhost:6379", // Required, e.g. "hostname:port"
    "Password": "", // Optional
    "ClientName": "", // Optional
    "KeepAlive": 120, // Optional, in seconds, default: 180
    "SslforAzure": false, // Optional, set true for Azure Redis, false for local Redis
    "AbortOnConnectFail": false // Optional, default: true
  },
    "Serilog": {
      //"Using": [ "Serilog.Sinks.MSSqlServer", "Serilog.Expressions" ],
      "Using": [ "Serilog.Expressions" ],
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "AppEngine.Logging.HttpContextEnricher": "Information", // Log HttpContextEnricher events at Information level to capture enriched properties, but avoid logging them at Warning level which would be too verbose
          "Microsoft": "Warning",
          "Microsoft.Hosting.Lifetime": "Information", // Override default Microsoft warning to information to log application start and stop events
          "Microsoft.AspNetCore.Identity": "Error",
          "Microsoft.EntityFrameworkCore": "Error",
          "Microsoft.EntityFrameworkCore.Infrastructure": "Warning", // Log EF Core infrastructure events like connection opening/closing, but not the actual database commands which are usually logged at Warning or Information level
          "Microsoft.EntityFrameworkCore.Database": "Warning", // Log EF Core database events like transactions, but not the actual database commands which are usually logged at Warning or Information level
          "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
          "System": "Warning"
        }
      },
      "WriteTo": [
        {
          "Name": "Console",
          "Args": {
            "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
            "outputTemplate": "{Timestamp:HH:mm:ss}\t{Level:u3}\t{SourceContext}\t{Message}{NewLine}{Exception}"
          }
        }
        //{
        //    "Name": "MSSqlServer",
        //    "Args": {
        //        "connectionString": "LogsConnection",
        //        "sinkOptionsSection": {
        //            "tableName": "Logs",
        //            "autoCreateSqlTable": true
        //        },
        //        "restrictedToMinimumLevel": "Information",
        //        "columnOptionsSection": {
        //            "addStandardColumns": [ "LogEvent", "TraceId", "SpanId" ],
        //            "removeStandardColumns": [ "MessageTemplate", "Properties" ],
        //            "additionalColumns": [
        //                {
        //                    "ColumnName": "UserName",
        //                    "PropertyName": "UserName",
        //                    "DataType": "nvarchar",
        //                    "DataLength": 255,
        //                    "AllowNull": true
        //                }
        //            ],
        //            "id": { "dataType": "bigint" },
        //            "timeStamp": {
        //                "columnName": "Timestamp",
        //                "convertToUtc": true,
        //                "nonClusteredIndex": true,
        //                "nonClusteredIndexDirection": "Desc"
        //            },
        //            "logEvent": {
        //                "excludeAdditionalProperties": false,
        //                "excludeStandardColumns": false
        //            }
        //        }
        //    }
        //}
      ],
      "Filter": [
        {
          "Name": "ByExcluding",
          "Args": {
            "expression": "RequestMethod = 'OPTIONS' OR RequestPath LIKE '/openapi/%' ci OR RequestPath = '/robots.txt' ci OR RequestPath = '/robots933456.txt' ci OR RequestPath = '/sitemap.txt' ci OR RequestPath = '/favicon.ico' ci OR RequestPath = '/.well-known/traffic-advice' ci"
          }
        }
      ],
      "Enrich": [ "FromLogContext" ]
    },
    "AllowedHosts": "*"
}